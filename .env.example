######################################################################
# dots-password-manager-v4 Environment Example
#
# Copy this file to .env.local and fill in values for your environment.
# Lines starting with # are comments and will be ignored.
######################################################################

# JWT refresh token expiration (in days, e.g. 7)
JWT_REFRESH_TOKEN_EXP_DAYS=

# Base64-encoded key for vault encryption (do not share)
CRYPTO_BASE_64_KEY=

# Comma-separated list of allowed origins for CORS (e.g. http://localhost:4200)
CORS_ALLOWED_ORIGINS=

# Public URL of the web app (used in emails)
WEBAPP_HOST=

# SendGrid API key for transactional email (if using SendGrid)
SENDGRID_API_KEY=

# Email address for outgoing mail (e.g. noreply@yourdomain.com)
FROM_ADDRESS=

# Database connection split variables (used if DATABASE_URL is not set)
DATABASE_PROTOCOL= # e.g. postgresql
DATABASE_HOST=     # e.g. localhost or your-db-host
DATABASE_PORT=     # e.g. 5432
DATABASE_NAME=     # e.g. postgres
DATABASE_USER=     # e.g. postgres
DATABASE_PASSWORD= # your database password (no quotes)

# Optional: PostgreSQL SSL mode (e.g. require, prefer, disable)
DATABASE_SSLMODE=
