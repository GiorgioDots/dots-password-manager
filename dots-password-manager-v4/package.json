{
    "name": "dots-password-manager-v4",
    "private": true,
    "type": "module",
    "imports": {
        "#/*": "./src/*"
    },
    "scripts": {
        "dev": "bun --bun vite dev --port 3000",
        "build": "bun --bun vite build",
        "preview": "bun --bun vite preview",
        "start": "bun run .output/server/index.mjs",
        "test": "vitest run",
        "db:generate": "bun --bun drizzle-kit generate",
        "db:migrate": "bun --bun drizzle-kit migrate",
        "db:push": "bun --bun drizzle-kit push",
        "db:pull": "bun --bun drizzle-kit pull",
        "db:studio": "bun --bun drizzle-kit studio",
        "lint": "eslint",
        "format": "bun --bun prettier --check .",
        "check": "bun --bun prettier --write . && bun --bun eslint --fix",
        "docker:build": "docker build -t ghcr.io/giorgiodots/dots-password-manager:prodv4 .",
        "docker:push": "docker push ghcr.io/giorgiodots/dots-password-manager:prodv4",
        "docker:run": "docker run -p 3000:3000 --env-file .env.local ghcr.io/giorgiodots/dots-password-manager:prodv4",
        "docker:preview": "bun run docker:build && bun run docker:run",
        "deploy:docker": "bun run docker:build && bun run docker:push"
    },
    "dependencies": {
        "@base-ui/react": "^1.3.0",
        "@fontsource-variable/geist": "^5.2.8",
        "@hugeicons/core-free-icons": "^4.1.1",
        "@hugeicons/react": "^1.1.6",
        "@tailwindcss/vite": "^4.1.18",
        "@tanstack/react-devtools": "latest",
        "@tanstack/react-form-start": "^1.29.0",
        "@tanstack/react-router": "latest",
        "@tanstack/react-router-devtools": "latest",
        "@tanstack/react-router-ssr-query": "latest",
        "@tanstack/react-start": "latest",
        "@tanstack/router-plugin": "^1.132.0",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.2",
        "jsonwebtoken": "^9.0.3",
        "lucide-react": "^1.8.0",
        "nitro": "^3.0.260311-beta",
        "nodemailer": "^8.0.5",
        "pg": "^8.20.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "shadcn": "^4.2.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.1.18",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.16",
        "@tanstack/devtools-vite": "latest",
        "@tanstack/eslint-config": "^0.4.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.10.2",
        "@types/nodemailer": "^8.0.0",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^5.1.4",
        "dotenv": "^17.4.1",
        "jsdom": "^28.1.0",
        "prettier": "^3.8.2",
        "typescript": "^5.7.2",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.0.5"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "lightningcss"
        ]
    }
}
